# ================================
# SERVEUR
# ================================
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ================================
# BASE DE DONNÉES (PostgreSQL)
# ================================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/saas_senegal?schema=public"

# ================================
# REDIS (Cache & Sessions)
# ================================
REDIS_URL="redis://localhost:6379"

# ================================
# JWT (Authentification)
# ================================
JWT_SECRET="change-this-super-secret-jwt-key-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-this-refresh-secret-too"
JWT_REFRESH_EXPIRES_IN="30d"

# ================================
# WAVE (Paiement Mobile Money)
# ================================
WAVE_API_KEY=""
WAVE_BUSINESS_ID=""
WAVE_WEBHOOK_SECRET=""

# ================================
# ORANGE MONEY
# ================================
ORANGE_CLIENT_ID=""
ORANGE_CLIENT_SECRET=""
ORANGE_MERCHANT_KEY=""

# ================================
# AFRICA'S TALKING (SMS/USSD)
# ================================
AT_API_KEY=""
AT_USERNAME=""
AT_SENDER_ID="SaaSSN"

# ================================
# WHATSAPP BUSINESS
# ================================
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
WHATSAPP_VERIFY_TOKEN=""

# ================================
# STOCKAGE FICHIERS
# ================================
STORAGE_TYPE="local"   # local | s3 | minio
STORAGE_LOCAL_PATH="./uploads"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ================================
# EMAIL (SendGrid)
# ================================
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@votreplateforme.sn"
EMAIL_FROM_NAME="SaaS Sénégal"

# ================================
# CORS
# ================================
ALLOWED_ORIGINS="http://localhost:3000,https://votre-app.sn"

# ================================
# RATE LIMITING
# ================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ================================
# UPLOAD FICHIERS
# ================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ================================
# EMAIL (Nodemailer / SMTP)
# ================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=""
EMAIL_FROM="noreply@votreplateforme.sn"
EMAIL_FROM_NAME="SaaS Sénégal"

# ================================
# WEBSOCKET
# ================================
WS_CORS_ORIGIN="http://localhost:3000"

# ================================
# CRON JOBS
# ================================
ENABLE_CRON=true
